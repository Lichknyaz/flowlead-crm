# Create a Supabase project, then copy these values from Project Settings > API.
# Without them, FlowLead CRM automatically runs in local portfolio-demo mode.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Set to true only after deploying and configuring the notify-new-lead Edge Function.
VITE_ENABLE_NOTIFICATIONS=false
